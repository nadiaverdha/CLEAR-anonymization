  "rules": [
    {
      "id": "1efe0ce1",
      "name": "Company Handel/Bildung",
      "description": "Matches company names ending in 'Handel' or 'Bildung', handling '+' and ignoring 'Firma' prefix.",
      "format": "regex",
      "content": "(?<!Firma\\s)([A-Z][a-zA-Z0-9\\s\\+&]*?(?:Handel|Bildung))(?=\\s*(?:GmbH?|AG|OG|\\.|,|\\)|$|\\n))",
      "priority": 8,
      "output_template": {
        "text": "$1",
        "start": "$start",
        "end": "$end",
        "type": "organisation"
      },
      "output_key": "entities",
      "created_at": "2026-05-13T11:06:22.542750"
    },
    {
      "id": "e168ff2d",
