      "content": "(?:Mag\\.|Dr\\.|Dr\\.in|Univ\\.-Prof\\.|Univ\\.-Prof\\.in|Priv\\.-Doz\\.|Priv\\.-Doz\\.in|\u00d6kR|Hon\\.-Prof\\.|Hon\\.-Prof\\. Dr\\.|PhD|StR|Bakk\\. art\\. MA|BA|RgR|KommR|MSc|Mag\\.a|VetR|OSR|OMedR|MedR|Ing\\.|RA|Bakk\\. rer\\. nat\\.)(?:\\s+(?:Mag\\.|Dr\\.|Dr\\.in|Univ\\.-Prof\\.|Univ\\.-Prof\\.in|Priv\\.-Doz\\.|Priv\\.-Doz\\.in|\u00d6kR|Hon\\.-Prof\\.|Hon\\.-Prof\\. Dr\\.|PhD|StR|Bakk\\. art\\. MA|BA|RgR|KommR|MSc|Mag\\.a|VetR|OSR|OMedR|MedR|Ing\\.|RA|Bakk\\. rer\\. nat\\.)?)*\\s+([A-Z][a-z\u00e4\u00f6\u00fc\u00df]+(?:\\s+[A-Z][a-z\u00e4\u00f6\u00fc\u00df]+)*)(?:,\\s*(?:LLM|LLB|MSc|BEd|Mag\\.a|Dr\\.in|Dr\\.|MedR|StR|PhD|Bakk\\. art\\. MA|BA|RgR|KommR|VetR|OSR|\u00d6kR|Bakk\\. rer\\. nat\\.)?)?",
