      "content": "(?:in\\s+der\\s+(?:Beschwerdesache|Revisionssache|Verwaltungsstrafsache|Verfahren|Sache)\\s+|des\\s+|der\\s+|dem\\s+|einer\\s+|einem\\s+|eingetragenen\\s+|bestehend\\s+aus\\s+dem\\s+|bestehend\\s+aus\\s+einer\\s+)([A-Z][a-z\\u00e4\\u00f6\\u00fc\\u00df]+(?:\\s+[A-Z][a-z\\u00e4\\u00f6\\u00fc\\u00df]+)+)(?:\\s*,\\s*(?:BA|LLB|LL\\.M|MSc|PhD|Dr\\.|Mag\\.|Mag\\.a|Mag\\.in|Prof\\.|Univ\\.-Prof\\.|Univ\\.-Prof\\.in|Priv\\.-Doz\\.|Priv\\.-Doz\\.in|Hon\\.-Prof\\.|Hon\\.-Prof\\.in|KommR|KzlR|Ing\\.|Dipl\\.-Ing\\.|RgR|StB|Stb|MAS|B\\.?A\\.?\\s+iur|Bakk\\.\\s+art\\.\\s+MA|techn\\.|OMedR|MedR|Dr\\.in|DDr\\.in|Bakk\\.\\s+rer\\.\\s+nat\\.)\\s*)?(?=\\s*,|\\s+\\n|\\s+\\d+|\\u00d6sterreich|\\s*\\(|\\s*\\)|\\s*\\.|\\s*\"|\\s*'|\\s+\\s|$|\\s+sei|\\s+ist|\\s+hat|\\s+war|\\s+GmbH|\\s+KG|\\s+AG|\\s+OHG|\\s+UG|\\s+GmbH\\s*&|\\s+GmbH\\s*&\\s*Co|\\s+vertreten|\\s+und|\\s+oder|\\s+geb\\.?|\\s+geboren|\\s+am|\\s+im|\\s+zu|\\s+von|\\s+bei|\\s+in|\\s+an|\\s+auf|\\s+mit|\\s+aus|\\s+nach|\\s+\\u00fcber|\\s+unter|\\s+zwischen|\\s+ohne|\\s+neben|\\s+um|\\s+seit|\\s+bis|\\s+ab|\\s+vor|\\s+statt|\\s+au\\u00dfer|\\s+gegen\\u00fcber|\\s*\\)|\\s*\\.|\\s*\\n|\\s*$)",
